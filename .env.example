# API Keys
ANTHROPIC_API_KEY=your_anthropic_key_here
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_PROJECT=adapt-ai

# Model Configuration
MODEL_NAME=claude-3-5-haiku-20241022
MAX_TOKENS_PER_REQUEST=4000
MODEL_TEMPERATURE=0.7

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=60
COST_ALERT_THRESHOLD=10.0

# Database Paths
VECTOR_DB_PATH=./data/chroma_db
SESSION_DB_PATH=./data/sessions.db
METRICS_DB_PATH=./data/metrics.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/adapt-ai.log

# Embedding Configuration (using sentence-transformers, no OpenAI needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# LLM Provider (default: anthropic; set to openai_compatible for Ollama/vLLM)
# LLM_PROVIDER=anthropic
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=                         # leave blank for Ollama (no key needed)

# LLM-as-judge (must be a different model than the system-under-test)
# JUDGE_PROVIDER=anthropic
# JUDGE_MODEL=claude-opus-4-8
# JUDGE_BASE_URL=                       # only needed if judge is on a different endpoint
# JUDGE_API_KEY=                        # only needed if judge is on a paid endpoint
