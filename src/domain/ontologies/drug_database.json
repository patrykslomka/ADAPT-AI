{
  "version": "1.0",
  "medications": [
    {
      "id": "trimethoprim_sulfamethoxazole",
      "generic_name": "Trimethoprim-Sulfamethoxazole",
      "brand_names": ["Bactrim", "Septra"],
      "drug_class": "Sulfonamide Antibiotic",
      "indications": [
        "urinary_tract_infection",
        "pneumocystis_pneumonia",
        "mrsa_skin_infection"
      ],
      "typical_dose": "1 DS tablet BID or 160/800mg BID",
      "contraindications": [
        {
          "condition": "sulfa_allergy",
          "severity": "absolute",
          "reason": "Risk of severe allergic reaction including Stevens-Johnson syndrome",
          "alternative": "Use fluoroquinolone or nitrofurantoin for UTI"
        },
        {
          "condition": "severe_renal_impairment",
          "severity": "absolute",
          "creatinine_threshold": "> 2.0 mg/dL",
          "reason": "Risk of toxic accumulation"
        },
        {
          "condition": "pregnancy_third_trimester",
          "severity": "absolute",
          "reason": "Risk of kernicterus in newborn"
        },
        {
          "condition": "g6pd_deficiency",
          "severity": "absolute",
          "reason": "Risk of hemolytic anemia"
        }
      ],
      "drug_interactions": [
        {
          "drug": "warfarin",
          "severity": "major",
          "mechanism": "Inhibits warfarin metabolism",
          "clinical_effect": "Increased INR, bleeding risk",
          "management": "Monitor INR closely, may need 20-30% warfarin dose reduction"
        },
        {
          "drug": "methotrexate",
          "severity": "major",
          "mechanism": "Both inhibit folate metabolism",
          "clinical_effect": "Bone marrow suppression, pancytopenia",
          "management": "Avoid combination if possible, monitor CBC weekly"
        },
        {
          "drug": "acei_arb",
          "severity": "moderate",
          "mechanism": "Both increase potassium",
          "clinical_effect": "Hyperkalemia",
          "management": "Monitor potassium levels"
        }
      ],
      "monitoring_parameters": [
        "renal_function",
        "cbc",
        "potassium"
      ],
      "common_side_effects": [
        "nausea",
        "rash",
        "hyperkalemia"
      ],
      "serious_side_effects": [
        "stevens_johnson_syndrome",
        "bone_marrow_suppression",
        "acute_kidney_injury"
      ]
    },
    {
      "id": "metformin",
      "generic_name": "Metformin",
      "brand_names": ["Glucophage", "Fortamet"],
      "drug_class": "Biguanide",
      "indications": [
        "type_2_diabetes",
        "prediabetes",
        "pcos"
      ],
      "typical_dose": "500-1000mg BID with meals",
      "max_dose": "2550mg/day",
      "contraindications": [
        {
          "condition": "severe_renal_impairment",
          "severity": "absolute",
          "egfr_threshold": "< 30 mL/min",
          "reason": "Risk of lactic acidosis"
        },
        {
          "condition": "acute_metabolic_acidosis",
          "severity": "absolute",
          "reason": "Worsens acidosis"
        },
        {
          "condition": "contrast_dye_use",
          "severity": "temporary",
          "reason": "Hold 48 hours around contrast procedures"
        }
      ],
      "drug_interactions": [
        {
          "drug": "alcohol",
          "severity": "major",
          "mechanism": "Both increase lactate",
          "clinical_effect": "Lactic acidosis risk",
          "management": "Limit alcohol intake"
        }
      ],
      "monitoring_parameters": [
        "renal_function",
        "b12_levels",
        "hba1c"
      ],
      "common_side_effects": [
        "gi_upset",
        "diarrhea",
        "nausea"
      ],
      "serious_side_effects": [
        "lactic_acidosis",
        "b12_deficiency"
      ]
    },
    {
      "id": "lisinopril",
      "generic_name": "Lisinopril",
      "brand_names": ["Zestril", "Prinivil"],
      "drug_class": "ACE Inhibitor",
      "indications": [
        "hypertension",
        "heart_failure",
        "diabetic_nephropathy"
      ],
      "typical_dose": "10-40mg daily",
      "contraindications": [
        {
          "condition": "angioedema_history",
          "severity": "absolute",
          "reason": "Risk of life-threatening angioedema"
        },
        {
          "condition": "pregnancy",
          "severity": "absolute",
          "reason": "Fetal toxicity"
        },
        {
          "condition": "bilateral_renal_artery_stenosis",
          "severity": "absolute",
          "reason": "Risk of acute kidney injury"
        }
      ],
      "drug_interactions": [
        {
          "drug": "potassium_supplements",
          "severity": "major",
          "mechanism": "Both increase potassium",
          "clinical_effect": "Hyperkalemia",
          "management": "Monitor potassium, avoid K supplements unless indicated"
        },
        {
          "drug": "nsaids",
          "severity": "moderate",
          "mechanism": "NSAIDs reduce ACE inhibitor efficacy",
          "clinical_effect": "Reduced BP control, increased renal risk",
          "management": "Use lowest NSAID dose for shortest duration"
        }
      ],
      "monitoring_parameters": [
        "blood_pressure",
        "renal_function",
        "potassium"
      ],
      "common_side_effects": [
        "dry_cough",
        "dizziness",
        "hyperkalemia"
      ],
      "serious_side_effects": [
        "angioedema",
        "acute_kidney_injury"
      ]
    },
    {
      "id": "warfarin",
      "generic_name": "Warfarin",
      "brand_names": ["Coumadin", "Jantoven"],
      "drug_class": "Vitamin K Antagonist",
      "indications": [
        "atrial_fibrillation",
        "dvt_pe",
        "mechanical_heart_valve"
      ],
      "typical_dose": "Variable, based on INR",
      "target_inr": "2.0-3.0 (higher for mechanical valves)",
      "contraindications": [
        {
          "condition": "active_bleeding",
          "severity": "absolute",
          "reason": "Will worsen bleeding"
        },
        {
          "condition": "pregnancy",
          "severity": "absolute",
          "reason": "Teratogenic"
        },
        {
          "condition": "severe_liver_disease",
          "severity": "relative",
          "reason": "Unpredictable response"
        }
      ],
      "drug_interactions": [
        {
          "drug": "aspirin",
          "severity": "major",
          "mechanism": "Additive bleeding risk",
          "clinical_effect": "Increased major bleeding",
          "management": "Use only if indicated, monitor closely"
        },
        {
          "drug": "rifampin",
          "severity": "major",
          "mechanism": "Induces warfarin metabolism",
          "clinical_effect": "Reduced anticoagulation",
          "management": "Monitor INR frequently, increase warfarin dose"
        },
        {
          "drug": "fluconazole",
          "severity": "major",
          "mechanism": "Inhibits warfarin metabolism",
          "clinical_effect": "Increased INR, bleeding",
          "management": "Reduce warfarin dose 25-50%"
        }
      ],
      "monitoring_parameters": [
        "inr",
        "signs_of_bleeding"
      ],
      "common_side_effects": [
        "bruising",
        "minor_bleeding"
      ],
      "serious_side_effects": [
        "major_bleeding",
        "intracranial_hemorrhage",
        "skin_necrosis"
      ]
    }
  ],
  "allergy_groups": [
    {
      "group_name": "sulfa",
      "description": "Sulfonamide antibiotics",
      "includes": [
        "trimethoprim_sulfamethoxazole",
        "sulfasalazine",
        "sulfadiazine",
        "sulfisoxazole"
      ],
      "cross_reactivity": {
        "within_group": "high",
        "with_sulfonamide_diuretics": "low",
        "with_sulfonylureas": "low"
      },
      "note": "True sulfa allergy involves sulfonamide antibiotic structure"
    },
    {
      "group_name": "penicillin",
      "description": "Beta-lactam antibiotics - Penicillin class",
      "includes": [
        "penicillin_vk",
        "amoxicillin",
        "ampicillin",
        "piperacillin"
      ],
      "cross_reactivity": {
        "within_group": "high",
        "with_cephalosporins": "moderate_5_10_percent",
        "with_carbapenems": "low_1_percent"
      }
    },
    {
      "group_name": "cephalosporins",
      "description": "Beta-lactam antibiotics - Cephalosporin class",
      "includes": [
        "cephalexin",
        "cefazolin",
        "ceftriaxone",
        "cefepime"
      ],
      "cross_reactivity": {
        "within_group": "high",
        "with_penicillins": "moderate_5_10_percent"
      }
    },
    {
      "group_name": "nsaids",
      "description": "Non-steroidal anti-inflammatory drugs",
      "includes": [
        "ibuprofen",
        "naproxen",
        "aspirin",
        "ketorolac"
      ],
      "cross_reactivity": {
        "within_group": "variable",
        "note": "Cross-reactivity depends on reaction type (IgE vs COX-1)"
      }
    }
  ]
}
