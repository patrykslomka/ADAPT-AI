  "treatments": [
    {
      "id": "rifampin",
      "name": "Rifampin",
      "generic_name": "rifampin",
      "brand_names": ["Rifadin"],
      "drug_class": "Antimycobacterial",
      "indications": ["tuberculosis", "latent_tb"],
      "mechanism": "Inhibits bacterial RNA synthesis",
      "typical_dose": "600mg daily (or 10mg/kg)",
      "max_dose": "600mg/day",
      "route": "PO",
      "contraindications": [
        "severe_liver_disease",
        "hypersensitivity"
      ],
      "common_side_effects": [
        "orange_discoloration_body_fluids",
        "hepatotoxicity",
        "gi_upset",
        "rash"
      ],
      "serious_side_effects": [
        "hepatotoxicity",
        "thrombocytopenia"
      ],
      "drug_interactions": [
        {
          "drug": "warfarin",
          "effect": "Decreased warfarin efficacy"
        },
        {
          "drug": "oral_contraceptives",
          "effect": "Decreased contraceptive efficacy"
        }
      ],
      "monitoring": ["liver_function_tests", "cbc"],
      "pregnancy_category": "C",
      "counseling_points": [
        "Take on empty stomach",
        "Body fluids may turn orange",
        "Use backup contraception",
        "Report yellowing of skin/eyes"
      ]
    },
    {
      "id": "aspirin",
      "name": "Aspirin",
      "generic_name": "acetylsalicylic acid",
      "brand_names": ["Ecotrin", "Bayer"],
      "drug_class": "Antiplatelet, NSAID",
      "indications": [
        "myocardial_infarction_stemi",
        "stroke_ischemic",
        "cad_prevention"
      ],
      "mechanism": "Irreversibly inhibits COX-1, preventing platelet aggregation",
      "typical_dose_acute_mi": "325mg (chewed)",
      "typical_dose_prevention": "81mg daily",
      "route": "PO",
      "contraindications": [
        "active_bleeding",
        "severe_thrombocytopenia",
        "aspirin_allergy"
      ],
      "common_side_effects": [
        "gi_upset",
        "heartburn"
      ],
      "serious_side_effects": [
        "gi_bleeding",
        "intracranial_hemorrhage"
      ],
      "drug_interactions": [
        {
          "drug": "warfarin",
          "effect": "Increased bleeding risk"
        },
        {
          "drug": "ibuprofen",
          "effect": "Decreased aspirin antiplatelet effect"
        }
      ],
      "monitoring": ["signs_of_bleeding"],
      "pregnancy_category": "D (third trimester)"
    },
    {
      "id": "amoxicillin",
      "name": "Amoxicillin",
      "generic_name": "amoxicillin",
      "brand_names": ["Amoxil", "Trimox"],
      "drug_class": "Beta-lactam Antibiotic",
      "indications": ["pneumonia_cap", "otitis_media", "sinusitis"],
      "mechanism": "Inhibits bacterial cell wall synthesis",
      "typical_dose": "500mg TID or 875mg BID",
      "route": "PO",
      "contraindications": [
        "penicillin_allergy",
        "severe_penicillin_reaction"
      ],
      "common_side_effects": [
        "diarrhea",
        "nausea",
        "rash"
      ],
      "serious_side_effects": [
        "anaphylaxis",
        "c_diff_colitis"
      ],
      "drug_interactions": [
        {
          "drug": "methotrexate",
          "effect": "Increased methotrexate toxicity"
        }
      ],
      "monitoring": ["signs_of_allergic_reaction"],
      "pregnancy_category": "B"
    },
    {
      "id": "insulin_regular",
      "name": "Regular Insulin",
      "generic_name": "insulin regular",
      "brand_names": ["Humulin R", "Novolin R"],
      "drug_class": "Insulin",
      "indications": ["diabetic_ketoacidosis", "hyperglycemia"],
      "mechanism": "Promotes glucose uptake into cells",
      "typical_dose_dka": "0.1 units/kg/hr IV infusion",
      "route": "IV, SubQ",
      "contraindications": [
        "hypoglycemia"
      ],
      "common_side_effects": [
        "hypoglycemia",
        "injection_site_reaction"
      ],
      "serious_side_effects": [
        "severe_hypoglycemia",
        "hypokalemia"
      ],
      "monitoring": ["blood_glucose", "potassium"],
      "pregnancy_category": "B"
    }
